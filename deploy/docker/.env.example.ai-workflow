# AI Workflow Generator - Environment Variables
#
# Copy this file to .env.ai-workflow and configure your values
#
# Usage:
#   cp .env.example.ai-workflow .env.ai-workflow
#   # Edit .env.ai-workflow with your values
#   docker-compose -f docker-compose.ai-workflow-generator.yml up -d

# ========================
# Required Configuration
# ========================

# FastGPT API Configuration
# URL of your FastGPT instance (including protocol)
FASTGPT_API_URL=http://host.docker.internal:3000

# FastGPT API Key (for LLM calls)
FASTGPT_API_KEY=your-fastgpt-api-key-here

# ========================
# Database Configuration
# ========================

# MongoDB Connection URI
# Default uses the container-defined MongoDB
MONGODB_URI=mongodb://aiworkflow:aiworkflow123@mongo-aiworkflow:27017/aiworkflow?authSource=admin

# Or use external MongoDB:
# MONGODB_URI=mongodb://username:password@your-mongo-host:27017/fastgpt?authSource=admin

# ========================
# Redis Configuration
# ========================

# Redis Connection URL
# Default uses the container-defined Redis
REDIS_URL=redis://:aiworkflow123@redis-aiworkflow:6379

# Or use external Redis:
# REDIS_URL=redis://:your-redis-password@your-redis-host:6379

# ========================
# Storage Configuration (Optional)
# ========================

# MinIO Endpoint (for file storage)
MINIO_ENDPOINT=minio-aiworkflow:9000

# MinIO Access Keys
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ========================
# Application Settings
# ========================

# Environment: development, staging, production
APP_ENV=development

# Log Level: debug, info, warning, error
LOG_LEVEL=debug

# Server Port (inside container)
PORT=8000

# ========================
# External Services (Optional)
# ========================

# If you want to connect to existing FastGPT services instead of running new ones:
# - Comment out mongo-aiworkflow, redis-aiworkflow, minio-aiworkflow services in docker-compose
# - Set MONGODB_URI and REDIS_URL to point to your existing services

# ========================
# LLM Configuration (vLLM)
# ========================

# vLLM API Base URL (for AI Workflow generation brain)
# Your vLLM server endpoint
VLLM_BASE_URL=http://165.154.97.202:38004

# Model to use for intent analysis and workflow generation
# Available models:
# - Qwen3-235B-A22B-Instruct-2507
# - Qwen3-235B-A22B-Thinking-2507
# - Qwen3-Next-80B-A3B-Thinking
# - Qwen3-Next-80B-A3B-Instruct
# - GLM-4.7-Flash
# - GPT-OSS-120B
# - Seed-OSS-36B-Instruct
# - Qwen3-Coder-Next
VLLM_MODEL=Qwen3-235B-A22B-Thinking-2507

# vLLM API Key (if required)
VLLM_API_KEY=
